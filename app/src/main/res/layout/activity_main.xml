<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1117"
    tools:context=".activities.MainActivity">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="12dp"
        android:background="#161B22">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔥 JIO GOD MODE v2.0"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#00E5FF" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="❌ INACTIVE"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FF0000"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Speed Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center"
        android:background="#1E2530">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvDownloadSpeed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#00FF00" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↓ Mbps"
                android:textSize="10sp"
                android:textColor="#B0BEC5" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvUploadSpeed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#00FFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↑ Mbps"
                android:textSize="10sp"
                android:textColor="#B0BEC5" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvPing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FF6B00" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ms"
                android:textSize="10sp"
                android:textColor="#B0BEC5" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvISP"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jio MP"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#7C4DFF" />

            <TextView
                android:id="@+id/tvNetworkType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4G/5G"
                android:textSize="10sp"
                android:textColor="#B0BEC5" />

        </LinearLayout>

    </LinearLayout>

    <!-- LIVE LOG TERMINAL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_margin="8dp"
        android:background="#0D1117">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📟 LIVE TERMINAL"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#00E5FF"
            android:padding="4dp"
            android:background="#161B22" />

        <ScrollView
            android:id="@+id/logScrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#010409"
            android:padding="4dp"
            android:scrollbars="vertical">

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:textColor="#00FF00"
                android:lineSpacingExtra="2dp" />

        </ScrollView>

    </LinearLayout>

    <!-- Features Grid (Compact) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center"
        android:background="#161B22">

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchApn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" 
            android:text="APN " android:textSize="10sp" android:textColor="#B0BEC5" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchDns"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" 
            android:text="DNS " android:textSize="10sp" android:textColor="#B0BEC5" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" 
            android:text="Host " android:textSize="10sp" android:textColor="#B0BEC5" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchTunnel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" 
            android:text="Tunnel " android:textSize="10sp" android:textColor="#B0BEC5" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch5g"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" 
            android:text="5G" android:textSize="10sp" android:textColor="#B0BEC5" />

    </LinearLayout>

    <!-- ACTIVATE BUTTON -->
    <Button
        android:id="@+id/btnActivate"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_margin="8dp"
        android:text="🔥 ACTIVATE GOD MODE"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:background="@drawable/button_primary"
        android:textColor="#FFFFFF" />

    <!-- Bottom Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp"
        android:weightSum="3">

        <Button
            android:id="@+id/btnSelectISP"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="⚡ PAYLOAD"
            android:textSize="11sp"
            android:background="@drawable/button_secondary"
            android:textColor="#00E5FF" />

        <Button
            android:id="@+id/btnClearLog"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="🗑️ CLEAR"
            android:textSize="11sp"
            android:background="@drawable/button_secondary"
            android:textColor="#00E5FF" />

        <Button
            android:id="@+id/btnSettings"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="⚙️ SETTINGS"
            android:textSize="11sp"
            android:background="@drawable/button_secondary"
            android:textColor="#00E5FF" />

    </LinearLayout>

</LinearLayout>
